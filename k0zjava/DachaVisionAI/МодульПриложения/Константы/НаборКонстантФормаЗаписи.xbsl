
@Обработчик
метод ПослеЗаписи()
    
    пер АдресВебхука = Запись.ВариантПодключения == "Telegram"
        ? Запись.Telegram_Webhook
        : Запись.Middleman_sendtobot
        
    ПослеЗаписиНаСервере(АдресВебхука)
    
;

@Локально
@НаСервере @ДоступноСКлиента
статический метод ПослеЗаписиНаСервере(Адрес: Строка)
    
    пер КлиентHttp = КлиентHttp.ЗапросGet(Адрес)
    КлиентHttp.Выполнить()
;