импорт МодульПриложения::Константы


метод MessagePOSTОбработкаЗапроса(Запрос: HttpСервисЗапрос)
    
    знч ТелоЗапроса = Запрос.Тело.ПрочитатьКакСтроку()
    если ТелоЗапроса.Пусто()
        возврат
    ;
    
    пер ОбработчикПосредник = не НаборКонстант.Получить().ВариантПодключения == "Telegram"
    
    если ОбработчикПосредник
        Интеграция_Middleman.ОбработатьВходящийЗапрос(ТелоЗапроса)    
    иначе
        Интеграция_Telegram.ОбработатьВходящийЗапрос(ТелоЗапроса)
    ;
;
